<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="bookRepository" class="com.cognizant.exercise.week2.springcore.ex7.BookRepository">
        <constructor-arg value="Spring Core Constructor Repository"/>
    </bean>
    
    <bean id="bookService" class="com.cognizant.exercise.week2.springcore.ex7.BookService">
        <constructor-arg ref="bookRepository"/>
        <property name="serviceName" value="Setter Service Property"/>
    </bean>

</beans>
